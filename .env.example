# Production Environment Variables Template
# 生产环境变量配置模板
# 
# ⚠️ SECURITY WARNING:
# - NEVER commit actual .env.production file to Git
# - This file (.env.example) contains only placeholders
# - Replace placeholder values with actual secrets in your local .env.production
#
# 🔒 安全警告：
# - 切勿将实际的 .env.production 文件提交到 Git
# - 此文件仅包含占位符
# - 在本地 .env.production 中用真实密钥替换占位符

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Contact Email
CONTACT_EMAIL=your-contact-email@your-domain.com

# 通义千问 API Key（阿里云百炼大模型）
# Get your key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Cron Job Secret (for scheduled tasks)
# Generate a secure random string for production
CRON_SECRET=your_secure_cron_secret_here

# Optional: Email Service (if using Resend or other providers)
# RESEND_API_KEY=your_resend_api_key_here
